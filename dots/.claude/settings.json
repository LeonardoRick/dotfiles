{
    "permissions": {
        "allow": [
            "WebSearch",
            "WebFetch(domain:docs.n8n.io)",
            "WebFetch(domain:docs.dokploy.com)",
            "WebFetch(domain:raw.githubusercontent.com)",
            "WebFetch(domain:github.com)",
            "WebFetch(domain:developers.cloudflare.com)",
            "WebFetch(domain:www.npmjs.com)",
            "WebFetch(domain:opencode.ai)",
            "Bash(cat:*)",
            "Bash(find:*)",
            "Bash(ls:*)",
            "Bash(ps aux:*)",
            "Bash(sed -n:*)",
            "Bash(grep:*)",
            "Bash(pnpm dev:*)",
            "Bash(pnpm start:*)",
            "Bash(npx tsc:*)",
            "mcp__postman__getCollectionRequest",
            "mcp__postman__getCollection",
            "Bash(git pull:*)",
            "Bash(git mv:*)",
            "Bash(git add:*)",
            "Bash(gh repo view:*)",
            "Bash(gh repo list:*)"
        ]
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "permission_prompt",
                "hooks": [
                    {
                        "type": "command",
                        "command": "terminal-notifier -title 'Claude Code' -message \"Needs approval in $(basename $PWD)\" -execute \"open -a 'Visual Studio Code' '$PWD'\""
                    }
                ]
            },
            {
                "matcher": "idle_prompt",
                "hooks": [
                    {
                        "type": "command",
                        "command": "terminal-notifier -title 'Claude Code' -message \"Done working in $(basename $PWD)\" -execute \"open -a 'Visual Studio Code' '$PWD'\""
                    }
                ]
            }
        ]
    },
    "model": "opus",
    "enabledPlugins": {},
    "extraKnownMarketplaces": {
        "ui-ux-pro-max-skill": {
            "source": {
                "source": "github",
                "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
            }
        }
    }
}
