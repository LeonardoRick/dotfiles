{
    "$schema": "https://opencode.ai/config.json",
    "plugins": ["opencode-notifier"],
    "model": "moonshotai/kimi-k2.5",
    "permission": {
        "*": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
            "*": "ask",
            "explore": "allow",
        },
        "todoread": "allow",
        "todowrite": "allow",
        "skill": "allow",
        // granular webfetch domain rules not supported yet — allow all can be dangerous so keep an eye here
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
            "*": "ask",
            "cat *": "allow",
            "find *": "allow",
            "grep *": "allow",
            "head *": "allow",
            "ls *": "allow",
            "ps aux*": "allow",
            "rg *": "allow",
            "sed -n *": "allow",
            "tail *": "allow",
            "pnpm dev*": "allow",
            "pnpm start*": "allow",
            "npx tsc*": "allow",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git pull*": "allow",
            "git mv *": "allow",
            "git add *": "allow",
            "gh repo view*": "allow",
            "gh repo list*": "allow",
        },
    },
}
