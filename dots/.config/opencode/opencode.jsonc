{
    "$schema": "https://opencode.ai/config.json",
    "model": "moonshotai/kimi-k2.5",
    "permission": {
        "*": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "skill": "allow",
        // granular webfetch domain rules not supported yet — allow all can be dangerous so keep an eye here
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
            "*": "ask",
            "find *": "allow",
            "ls *": "allow",
            "ps aux*": "allow",
            "sed -n *": "allow",
            "pnpm dev*": "allow",
            "pnpm start*": "allow",
            "npx tsc*": "allow",
            "git pull*": "allow",
            "git mv *": "allow",
            "git add *": "allow",
            "gh repo view*": "allow",
            "gh repo list*": "allow",
        },
    },
}
